<?xml version="1.0" encoding="utf-8"?>
<addons>
<addon id="plugin.video.ha-stream-cinema" name="HA Stream Cinema" version="0.2.1" provider-name="Pajan">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="main.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="cs_CZ">Kodi klient pro HA Stream Cinema API</summary>
        <summary lang="en_GB">Kodi client for HA Stream Cinema API</summary>
        <description lang="cs_CZ">Jednoduchý Kodi doplněk pro procházení sbírky filmů a seriálů z HA Stream Cinema, přehrávání a stahování uložených streamů.</description>
        <description lang="en_GB">A small Kodi add-on for browsing HA Stream Cinema movies and TV shows, playing and downloading stored streams.</description>
        <language>cs en</language>
        <platform>all</platform>
        <license>MIT</license>
        <assets>
            <icon>resources/media/icon.png</icon>
            <fanart>resources/media/fanart.jpg</fanart>
        </assets>
    </extension>
</addon>

<addon id="repository.pavelvraj.kodi-ha-streamcinema" name="Pajan's Kodi Add-ons" version="0.1.5" provider-name="Pajan">
    <extension point="xbmc.addon.repository" name="Pajan's Kodi Add-ons">
        <dir>
            <info compressed="false">https://pavelvraj.github.io/kodi-ha-streamcinema/addons.xml</info>
            <checksum>https://pavelvraj.github.io/kodi-ha-streamcinema/addons.xml.md5</checksum>
            <datadir zip="true">https://pavelvraj.github.io/kodi-ha-streamcinema/zips/</datadir>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="cs_CZ">Repository pro HA Stream Cinema Kodi doplněk</summary>
        <summary lang="en_GB">Repository for HA Stream Cinema Kodi add-on</summary>
        <description lang="cs_CZ">Online repository pro instalaci a aktualizace Kodi doplňku HA Stream Cinema.</description>
        <description lang="en_GB">Online repository for installing and updating the HA Stream Cinema Kodi add-on.</description>
        <platform>all</platform>
        <assets>
            <icon>resources/media/icon.png</icon>
            <fanart>resources/media/fanart.jpg</fanart>
        </assets>
    </extension>
</addon>

</addons>

